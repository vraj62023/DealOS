# Port to run the server on (defaults to 5000)
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dealos?retryWrites=true&w=majority

# Google Gemini API Key for AI features
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key for signing JWT tokens
JWT_SECRET=your_jwt_secret_here

# Cloudinary configuration for document/image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Secret key for HMAC webhook verification (optional/production)
WEBHOOK_SECRET=your_webhook_secret_here
